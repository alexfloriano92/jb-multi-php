# ─────────────────────────────────────────────────────────────
# .htaccess UNIFICADO para Locaweb Go
# Coloque este arquivo em public_html/.htaccess (renomeando para .htaccess)
# Ele roteia:
#   /api/*  → Laravel (index.php)
#   /*      → React SPA (index.html)
# Arquivos reais (assets, uploads) passam direto.
# ─────────────────────────────────────────────────────────────

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Força HTTPS (opcional — descomente se quiser)
  # RewriteCond %{HTTPS} !=on
  # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Remove barra final (exceto raiz)
  RewriteRule ^(.+)/$ /$1 [L,R=301]

  # ── 1. Rotas da API vão para o Laravel ─────────────────────
  RewriteCond %{REQUEST_URI} ^/api
  RewriteRule ^ index.php [L]

  # ── 2. Arquivos e pastas que existem de verdade passam ─────
  #    (assets do React, uploads de fotos, favicon, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ── 3. Todo o resto vai para o React (SPA) ────────────────
  RewriteRule ^ index.html [L]
</IfModule>

# ─── Cache de assets estáticos (performance) ────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg              "access plus 1 year"
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType text/css               "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2             "access plus 1 year"
</IfModule>

# ─── Compressão GZIP ────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ─── Segurança: bloqueia acesso a arquivos sensíveis ────────
<FilesMatch "^\.env|composer\.(json|lock)|package(-lock)?\.json$">
  Require all denied
</FilesMatch>