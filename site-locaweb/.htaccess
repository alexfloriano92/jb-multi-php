# JB Multimarcas — site estático
Options -Indexes

# Segurança básica
<Files ".htaccess">
  Require all denied
</Files>

# Cache de assets estáticos
#  - Imagens: podem ficar guardadas 30 dias (raramente mudam).
#  - HTML/CSS/JS: NÃO ficam guardados. O navegador sempre pergunta ao
#    servidor "essa versão ainda é a mais nova?"; se for, vem só um 304
#    (sem baixar de novo, então continua rápido). Assim, quando você
#    publica uma alteração, o cliente NÃO precisa limpar cache/cookies
#    no celular para ver a versão nova.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png  "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType text/css              "access plus 0 seconds"
  ExpiresByType application/javascript "access plus 0 seconds"
  ExpiresByType text/html             "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # HTML / CSS / JS: sempre revalidar antes de usar do cache.
  <FilesMatch "\.(html|htm|css|js|json)$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>

  # Imagens: podem ficar 30 dias no cache.
  <FilesMatch "\.(png|jpe?g|webp|svg|ico|gif)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# Compressão gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Página padrão
DirectoryIndex index.html